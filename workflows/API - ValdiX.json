    {
      "parameters": {
        "jsCode": "const webhookData = $('Webhook').first().json;\nconst httpData = $input.all();\n\nconst ideia = webhookData.body?.ideia || '';\nconst historico = webhookData.body?.historico || [];\n\nconst contexto = httpData.map(item => {\n  const r = item.json;\n  return `${r.resumo || ''} ${r.tendencias || ''} ${r.oportunidades || ''}`;\n}).join(' ').slice(0, 2000);\n\nconst historicoFormatado = historico.map(msg => \n  `${msg.role === 'user' ? 'Usuário' : 'ValidX'}: ${msg.content}`\n).join('\\n');\n\nreturn [{\n  json: {\n    ideia,\n    contexto,\n    historico: historicoFormatado\n  }\n}];"
      },
