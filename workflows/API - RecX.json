    {
      "parameters": {
        "jsCode": "const webhookData = $('Webhook').first().json;\nconst httpData = $input.all();\n\nconst areaEscolhida = webhookData.body?.area || 'tecnologia';\n\nconst relatorios = httpData.map(item => {\n  const r = item.json;\n  return `${r.resumo || ''} ${r.tendencias || ''} ${r.oportunidades || ''}`;\n}).join(' ');\n\nreturn [{\n  json: {\n    area: areaEscolhida,\n    contexto: relatorios.slice(0, 3000)\n  }\n}];"
