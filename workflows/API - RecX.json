    {
      "parameters": {
        "jsCode": "const webhookData = $('Webhook').first().json;\nconst httpData = $input.all();\n\nconst area = webhookData.body?.area || 'geral';\nconst mensagem = webhookData.body?.mensagem || '';\nconst historico = webhookData.body?.historico || [];\n\n// Monta contexto dos relatórios\nconst contexto = httpData.map(item => {\n  const r = item.json;\n  return `${r.resumo || ''} ${r.tendencias || ''} ${r.oportunidades || ''}`;\n}).join(' ').slice(0, 2500);\n\n// Formata histórico da conversa\nconst historicoFormatado = historico.map(msg =>\n  `${msg.role === 'user' ? 'Usuário' : 'RecX'}: ${msg.content}`\n).join('\\n');\n\nreturn [{\n  json: {\n    area,\n    mensagem,\n    contexto,\n    historico: historicoFormatado\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
